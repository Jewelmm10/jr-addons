{
  "name": "jr-addons",
  "version": "1.0.0",
  "description": "Custom Elementor Widgets & Addons by Jewel Rahman",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/jr-addons.css --watch",
    "dev:admin": "npx @tailwindcss/cli -i ./assets/css/admin-tailwind.css -o ./assets/css/admin.css --watch",
    "build": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/jr-addons.min.css --minify",
    "build:prod": "npm run build"
  },
  
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jewelmm10/jr-addons.git"
  },
  "author": "Jewel Rahman <your@email.com>",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/Jewelmm10/jr-addons/issues"
  },
  "homepage": "https://github.com/Jewelmm10/jr-addons#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.0.0"
  }
}
