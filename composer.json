{
  "name": "jewelmm10/jr-addons",
  "version": "1.0.0",
  "description": "Custom Elementor Widgets & Addons by Jewel Rahman. Core functionality for JR core theme including widgets, CPTs, and theme features.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Md Jewel Miah",
      "email": "jewelmm9@gmail.com",
      "role": "Developer",
      "homepage": "https://github.com/jewelmm10"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "JR_Addons\\": "includes/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=WordPress --extensions=php --ignore=vendor,.git,assets .",
    "lint:fix": "phpcbf --standard=WordPress --extensions=php --ignore=vendor,.git,assets .",
    "format": "@lint:fix",
    "test": "echo 'No tests configured yet'"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}